# ---- AlloyDB connection via Python connector ----
ALLOYDB_INSTANCE_URI=projects/dotengage/locations/us-central1/clusters/aia-alloydb/instances/aia-alloydb-primary
ALLOYDB_USER=aia-alloydb
ALLOYDB_PASSWORD=Alloydb
ALLOYDB_DATABASE=postgres
ALLOYDB_TABLE_SCHEMA=alloydb_usecase
IP_TYPE=PUBLIC

GCP_PROJECT=dotengage
VERTEX_LOCATION=us-central1
FRAME_SAMPLE_PER_SEC=1.0
EMBED_DIM=1408
USE_GCS=false 

# ---------- Embedding model ----------
# Default is intfloat/e5-base (already hard-coded). Override here if you customize.
TEXT_EMBED_MODEL=intfloat/e5-base

# DEFAULT VALUES
TOP_K_DEFAULT = 10
SIM_THRESHOLD_DEFAULT = 0.05
IVF_FLAT_PROBES = 1
HNSW_EF_SEARCH = 40
 