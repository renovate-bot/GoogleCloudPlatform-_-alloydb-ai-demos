
# Cloud SQL instance connection string
# INSTANCE_CONNECTION_NAME=dotengage:us-central1:cloudsql-mysql-instance
INSTANCE_CONNECTION_NAME=dotengage:us-central1:cloudsql-mysql-instance-vertexai
# Choose PUBLIC or PRIVATE depending on your instance’s IP type
CLOUDSQL_IP_TYPE=PUBLIC
# ---- Auth options ----
# A) Password Auth (traditional MySQL user/password)

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=app_user
MYSQL_PASSWORD=Mysql@dev1
MYSQL_DB_NAME=cloudsql_usecase
MYSQL_TABLE_SCHEMA=cloudsql_usecase

# B) IAM DB Auth (no password needed if enabled)
# Set to "true" if your instance has IAM DB authentication enabled and
# you have an IAM-authenticated MySQL user (e.g., your GCP identity).
MYSQL_IAM_AUTH=false

# ---------- Google Cloud ----------
PROJECT_ID=dotengage
REGION=us-central1
GCS_BUCKET=retail_gcs-20250917

MAX_ROWS=5000
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIM=768
VERTEX_LOCATION=us-central1
INSTANCE=cloudsql-mysql-instance-vertexai
